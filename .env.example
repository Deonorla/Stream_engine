# ===========================================
# Stella's Stream Engine Environment Variables
# ===========================================

# -------------------------------------------
# NETWORK CONFIGURATION
# -------------------------------------------

STREAM_ENGINE_RUNTIME_KIND=stellar
STREAM_ENGINE_NETWORK_NAME=Stellar Testnet
STREAM_ENGINE_BLOCK_EXPLORER_URL=https://stellar.expert/explorer/testnet
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Stellar USDC / SAC configuration
STELLAR_ASSET_CODE=USDC
STELLAR_ASSET_ISSUER=your_testnet_usdc_issuer_here
STELLAR_ASSET_DECIMALS=7
STELLAR_USDC_SAC_ADDRESS=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
STELLAR_NATIVE_XLM_SAC_ADDRESS=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
STREAM_ENGINE_PAYMENT_TOKEN_ADDRESS=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
STREAM_ENGINE_PAYMENT_TOKEN_SYMBOL=USDC
STREAM_ENGINE_PAYMENT_TOKEN_DECIMALS=7

# Backend signer / operator
PRIVATE_KEY=your_private_key_here
STELLAR_OPERATOR_SECRET=your_stellar_operator_secret_here
STELLAR_OPERATOR_PUBLIC_KEY=G...
STELLAR_PLATFORM_ADDRESS=G...

# Agent wallet (server-side keypair for autonomous agent actions)
# Generate with: stellar keys generate --network testnet
AGENT_SECRET_KEY=S...
# 32-byte hex key for encrypting per-user agent secrets in the DB
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_ENCRYPTION_KEY=your_64_char_hex_here
# Secret for signing agent session JWTs (can reuse AGENT_ENCRYPTION_KEY or set separately)
AGENT_JWT_SECRET=your_jwt_secret_here

# AI
GEMINI_API_KEY=your_gemini_api_key_here

# App / storage
STREAM_ENGINE_RECIPIENT_ADDRESS=G...
STREAM_ENGINE_APP_BASE_URL=http://localhost:5173
PINATA_JWT=your_pinata_jwt_here
IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/stream_engine
RWA_INDEXER_START_BLOCK=0

# Runtime ids
STREAM_ENGINE_CONTRACT_ADDRESS=CBC4DKMWZTHTA35LHKNWYNC5DNVT4VBRZLR7YF7HMZIDYJTAUECIAMHE
