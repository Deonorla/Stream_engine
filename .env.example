# ===========================================
# Stream Engine Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# -------------------------------------------
# ACTIVE NETWORK
# Options: "sepolia" (default) | "polkadot"
# -------------------------------------------
VITE_ACTIVE_NETWORK=sepolia

# -------------------------------------------
# ETHEREUM SEPOLIA (current)
# -------------------------------------------
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
PRIVATE_KEY=your_private_key_here

VITE_CONTRACT_ADDRESS=0x155A00fBE3D290a8935ca4Bf5244283685Bb0035
VITE_MNEE_TOKEN_ADDRESS=0x96B1FE54Ee89811f46ecE4a347950E0D682D3896

# -------------------------------------------
# POLKADOT EVM (fill in once contracts are deployed)
# Set VITE_ACTIVE_NETWORK=polkadot to activate
# -------------------------------------------
# VITE_POLKADOT_CHAIN_ID=
# VITE_POLKADOT_CHAIN_ID_HEX=
# VITE_POLKADOT_RPC_URL=
# VITE_POLKADOT_EXPLORER_URL=
# VITE_POLKADOT_CONTRACT_ADDRESS=
# VITE_POLKADOT_MNEE_TOKEN_ADDRESS=

# -------------------------------------------
# AI FEATURES (Optional)
# -------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
