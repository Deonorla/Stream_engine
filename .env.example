# ===========================================
# FlowPay Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# Most variables are OPTIONAL - the app works without them!

# -------------------------------------------
# NETWORK CONFIGURATION (Required for deployment)
# -------------------------------------------

# Westend Asset Hub / EVM configuration
POLKADOT_RPC_URL=https://westend-asset-hub-eth-rpc.polkadot.io
POLKADOT_CHAIN_ID=420420421
FLOWPAY_NETWORK_NAME=Westend Asset Hub
FLOWPAY_BLOCK_EXPLORER_URL=https://westmint.subscan.io
FLOWPAY_NATIVE_CURRENCY_NAME=Westend
FLOWPAY_NATIVE_CURRENCY_SYMBOL=WND
FLOWPAY_NATIVE_CURRENCY_DECIMALS=18

# Circle USDC on Polkadot Westend / testnet asset registry
FLOWPAY_PAYMENT_ASSET_ID=31337
FLOWPAY_PAYMENT_TOKEN_ADDRESS=0x00007a6900000000000000000000000001200000
FLOWPAY_PAYMENT_TOKEN_SYMBOL=USDC
FLOWPAY_PAYMENT_TOKEN_DECIMALS=6

# Optional experimental Westend Asset Hub / Westmint target
WESTMINT_RPC_URL=https://westend-asset-hub-eth-rpc.polkadot.io
WESTMINT_CHAIN_ID=420420421
WESTMINT_NETWORK_NAME=Westend Asset Hub
WESTMINT_BLOCK_EXPLORER_URL=https://westmint.subscan.io
WESTMINT_NATIVE_CURRENCY_NAME=Westend
WESTMINT_NATIVE_CURRENCY_SYMBOL=WND
WESTMINT_NATIVE_CURRENCY_DECIMALS=18
WESTMINT_PAYMENT_ASSET_ID=31337
WESTMINT_PAYMENT_TOKEN_ADDRESS=0x00007a6900000000000000000000000001200000
WESTMINT_PAYMENT_TOKEN_SYMBOL=USDC
WESTMINT_PAYMENT_TOKEN_DECIMALS=6

# Optional Substrate-native account support for Westend Asset Hub testing
POLKADOT_SUBSTRATE_RPC_URL=wss://westend-asset-hub-rpc.polkadot.io
FLOWPAY_USE_SUBSTRATE_READS=true
FLOWPAY_USE_SUBSTRATE_WRITES=true
SUBSTRATE_JSON_PATH=./substrate.json
SUBSTRATE_PASSWORD=your_account_password_here
# Alternative to SUBSTRATE_JSON_PATH + SUBSTRATE_PASSWORD
# SUBSTRATE_SURI=your twelve word mnemonic or raw seed here
SUBSTRATE_WEIGHT_LIMIT_REF_TIME=900000000000
SUBSTRATE_WEIGHT_LIMIT_PROOF_SIZE=5242880
SUBSTRATE_STORAGE_DEPOSIT_LIMIT=5000000000000000000
SUBSTRATE_PAYMENT_TEST_AMOUNT=0.1
SUBSTRATE_RWA_TEST_AMOUNT=0.2
SUBSTRATE_RWA_FLASH_ADVANCE_AMOUNT=0.02

# Your wallet private key (for deploying contracts)
# ⚠️ NEVER commit your real private key to git!
PRIVATE_KEY=your_private_key_here

# -------------------------------------------
# AI FEATURES (Optional)
# -------------------------------------------

# Google Gemini API Key - Get from https://ai.google.dev/
# Required for AI-powered payment mode selection
GEMINI_API_KEY=your_gemini_api_key_here

# -------------------------------------------
# DEPLOYED CONTRACT ADDRESSES
# -------------------------------------------

# x402 recipient wallet exposed by the middleware
FLOWPAY_RECIPIENT_ADDRESS=0xyour_service_wallet_here

# Optional app base URL used when generating QR verification links
FLOWPAY_APP_BASE_URL=http://localhost:5173

# Optional Pinata JWT for IPFS metadata uploads
PINATA_JWT=your_pinata_jwt_here

# Optional custom IPFS gateway
IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs

# Optional Postgres URL for the repo-owned RWA indexer
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/flowpay

# Optional backfill start block for the RWA indexer
RWA_INDEXER_START_BLOCK=0

# Payment and RWA contract addresses after deployment
FLOWPAY_CONTRACT_ADDRESS=0xyour_flowpay_stream_here
VITE_CONTRACT_ADDRESS=0xyour_flowpay_stream_here
FLOWPAY_RWA_ASSET_NFT_ADDRESS=0xyour_asset_nft_here
FLOWPAY_RWA_ASSET_REGISTRY_ADDRESS=0xyour_asset_registry_here
FLOWPAY_RWA_COMPLIANCE_GUARD_ADDRESS=0xyour_compliance_guard_here
FLOWPAY_RWA_ASSET_STREAM_ADDRESS=0xyour_asset_stream_here
FLOWPAY_RWA_HUB_ADDRESS=0xyour_rwa_hub_here

# Frontend config
VITE_FLOWPAY_CHAIN_ID=420420421
VITE_FLOWPAY_NETWORK_NAME=Westend Asset Hub
VITE_FLOWPAY_RPC_URL=https://westend-asset-hub-eth-rpc.polkadot.io
VITE_FLOWPAY_SUBSTRATE_RPC_URL=wss://westend-asset-hub-rpc.polkadot.io
VITE_FLOWPAY_BLOCK_EXPLORER_URL=https://westmint.subscan.io
VITE_FLOWPAY_PAYMENT_ASSET_ID=31337
VITE_FLOWPAY_PAYMENT_TOKEN_ADDRESS=0x00007a6900000000000000000000000001200000
VITE_FLOWPAY_PAYMENT_TOKEN_SYMBOL=USDC
VITE_FLOWPAY_PAYMENT_TOKEN_DECIMALS=6
VITE_RWA_API_URL=http://localhost:3001
VITE_FLOWPAY_RWA_HUB_ADDRESS=0xyour_rwa_hub_here
VITE_FLOWPAY_RWA_ASSET_STREAM_ADDRESS=0xyour_asset_stream_here
