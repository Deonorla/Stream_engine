# ===========================================
# Stella's Stream Engine Environment Variables
# ===========================================

# -------------------------------------------
# NETWORK CONFIGURATION
# -------------------------------------------

STREAM_ENGINE_RUNTIME_KIND=stellar
STREAM_ENGINE_NETWORK_NAME=Stellar Testnet
STREAM_ENGINE_BLOCK_EXPLORER_URL=https://stellar.expert/explorer/testnet
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Stellar USDC / SAC configuration
STELLAR_ASSET_CODE=USDC
STELLAR_ASSET_ISSUER=your_testnet_usdc_issuer_here
STELLAR_ASSET_DECIMALS=7
STELLAR_USDC_SAC_ADDRESS=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
STELLAR_NATIVE_XLM_SAC_ADDRESS=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
STREAM_ENGINE_PAYMENT_TOKEN_ADDRESS=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
STREAM_ENGINE_PAYMENT_TOKEN_SYMBOL=USDC
STREAM_ENGINE_PAYMENT_TOKEN_DECIMALS=7

# Backend signer / operator
PRIVATE_KEY=your_private_key_here
STELLAR_OPERATOR_SECRET=your_stellar_operator_secret_here
STELLAR_OPERATOR_PUBLIC_KEY=G...
STELLAR_PLATFORM_ADDRESS=G...

# Agent wallet (server-side keypair for autonomous agent actions)
# Generate with: stellar keys generate --network testnet
AGENT_SECRET_KEY=S...
# 32-byte hex key for encrypting per-user agent secrets in the DB
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_ENCRYPTION_KEY=your_64_char_hex_here
# Secret for signing agent session JWTs (can reuse AGENT_ENCRYPTION_KEY or set separately)
AGENT_JWT_SECRET=your_jwt_secret_here
AGENT_LLM_ENABLED=true
AGENT_LLM_PROVIDER=gemini,groq,openrouter
AGENT_LLM_MODEL=gemini-2.5-flash
AGENT_LLM_PROVIDER_COOLDOWN_MS=60000
AGENT_MEMORY_SUMMARY_MIN_SECONDS=300

# Optional Auth0 protection for the managed-agent path
AUTH0_DOMAIN=your-tenant.region.auth0.com
AUTH0_AUDIENCE=your_api_audience
# If you copied the Management API issuer, the backend will also accept the root tenant issuer.
AUTH0_ISSUER=https://your-tenant.region.auth0.com/
# Claim that carries the Stellar owner wallet the managed agent should bind to
AUTH0_OWNER_PUBLIC_KEY_CLAIM=https://continuum.app/owner_public_key

# AI
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=Continuum

# App / storage
STREAM_ENGINE_RECIPIENT_ADDRESS=G...
STREAM_ENGINE_APP_BASE_URL=http://localhost:5173
PINATA_JWT=your_pinata_jwt_here
IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/stream_engine
# Dev stack (npm run start:all) can auto-start local Docker Postgres
STREAM_ENGINE_AUTO_START_POSTGRES=true
STREAM_ENGINE_POSTGRES_CONTAINER=stream-engine-postgres
STREAM_ENGINE_POSTGRES_IMAGE=postgres:16
RWA_INDEXER_START_BLOCK=0

# Runtime ids
STREAM_ENGINE_CONTRACT_ADDRESS=CDS4XG3PAOWRNFVFKMK7LKJEXFQIJXFAMX54F5T3EBNFLNOL3RMGSECX
STREAM_ENGINE_SESSION_API_URL=http://127.0.0.1:3001
DEMO_STELLAR_SENDER=G...
STREAM_ENGINE_RWA_OPERATOR_ADDRESSES=G...
STREAM_ENGINE_RWA_ASSET_NFT_ADDRESS=CCQ7RAHNLTGH2CF5BNNWAGFJLCB6EUV76K5ZQ4CWU42VF3FGZ5PJHNYK
STREAM_ENGINE_RWA_ASSET_REGISTRY_ADDRESS=CCQ7RAHNLTGH2CF5BNNWAGFJLCB6EUV76K5ZQ4CWU42VF3FGZ5PJHNYK
STREAM_ENGINE_RWA_ATTESTATION_REGISTRY_ADDRESS=CCSNBJYDCM546LAUAVUFXABRWRCAP7U77TTEU4CKHNXYQMU7BEWTYCGJ
STREAM_ENGINE_RWA_COMPLIANCE_GUARD_ADDRESS=CCQ7RAHNLTGH2CF5BNNWAGFJLCB6EUV76K5ZQ4CWU42VF3FGZ5PJHNYK
STREAM_ENGINE_RWA_ASSET_STREAM_ADDRESS=CBBAIM4NMQEZ5RX3ZIII7SLTZSG5GYZ6DOCEPTQV6N37NYPCYLBL6ZQO
STREAM_ENGINE_RWA_HUB_ADDRESS=CCQ7RAHNLTGH2CF5BNNWAGFJLCB6EUV76K5ZQ4CWU42VF3FGZ5PJHNYK

# Continuum treasury venue allowlists (JSON arrays)
CONTINUUM_SAFE_YIELD_VENUES=[{"id":"safe-core","label":"Safe Core","projectedNetApy":11.2,"capPct":60,"destination":"GSAFEYIELDDESTINATION"}]
CONTINUUM_BLEND_VENUES=[{"id":"blend-core","label":"Blend Core","projectedNetApy":13.5,"capPct":25,"contractId":"CBLENDCONTRACTID"}]
CONTINUUM_AMM_VENUES=[{"id":"amm-usdc-xlm","label":"USDC/XLM","projectedNetApy":12.1,"capPct":15,"liquidityPoolId":"POOLID","assetA":{"code":"USDC","issuer":"your_testnet_usdc_issuer_here"},"assetB":{"code":"XLM","issuer":""},"maxAmountB":"1","minPrice":"0.0000001","maxPrice":"10000000"}]

# Frontend
VITE_STREAM_ENGINE_RUNTIME_KIND=stellar
VITE_STREAM_ENGINE_CHAIN_ID=0
VITE_STREAM_ENGINE_NETWORK_NAME=Stellar Testnet
VITE_STREAM_ENGINE_RPC_URL=https://soroban-testnet.stellar.org
