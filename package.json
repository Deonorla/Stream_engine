{
  "name": "stream-engine",
  "version": "1.0.0",
  "description": "Stella's Stream Engine - x402-compatible agent payments and rental RWA verification on Stellar",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:contracts && npm run test:sdk && npm run test:web",
    "test:contracts": "npx hardhat test",
    "test:sdk": "npm --prefix sdk run test:all",
    "test:web": "npm --prefix vite-project run test",
    "test:integration": "npm --prefix sdk run test:integration",
    "test:stellar:contracts": "cargo test --manifest-path soroban/Cargo.toml",
    "dev": "npm --prefix vite-project run dev",
    "dev:stack": "node scripts/dev-stack.js",
    "start:all": "node scripts/dev-stack.js",
    "build:web": "npm --prefix vite-project run build",
    "build:stellar:contracts": "stellar contract build --manifest-path soroban/Cargo.toml --out-dir soroban/dist --optimize",
    "deploy:stellar:contracts": "node scripts/deploy-stellar-contracts.mjs",
    "preview": "npm --prefix vite-project run preview",
    "install:all": "npm install && npm --prefix sdk install && npm --prefix server install && npm --prefix vite-project install",
    "demo:provider": "npx ts-node --project demo/tsconfig.json demo/provider.ts",
    "demo:consumer": "npx ts-node --project demo/tsconfig.json demo/consumer.ts",
    "demo:check": "npx ts-node --project demo/tsconfig.json demo/check-setup.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "hardhat": "^2.26.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@stellar/stellar-sdk": "^14.6.1",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "ethers": "^6.11.1",
    "express": "^4.18.2",
    "serverless-http": "^4.0.0"
  }
}
